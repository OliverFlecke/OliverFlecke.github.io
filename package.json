{
	"name": "website",
	"version": "1.0.0",
	"author": "Oliver Fleckenstein <oliver@flecke.xyz>",
	"license": "MIT",
	"scripts": {
		"dev": "concurrently --kill-others --names \"HUGO,CSS\" -c \"bgBlue.bold,bgGreen.bold\" \"hugo server\" \"pnpm css\"",
		"css": "pnpm tailwindcss -i styles/main.css -o static/css/main.css -v --watch",
		"build": "pnpm tailwindcss -i styles/main.css -o static/css/main.css -v --minify",
		"fmt": "biome format --write",
		"lint": "biome lint"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@tailwindcss/cli": "^4.3.3",
		"concurrently": "^10.0.3",
		"cssnano": "^8.0.2",
		"tailwindcss": "4.3.3",
		"wrangler": "^4.112.0"
	}
}
