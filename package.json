	"scripts": {
		"dev": "concurrently --kill-others --names \"HUGO,CSS\" -c \"bgBlue.bold,bgGreen.bold\" \"hugo server\" \"pnpm css\"",
		"css": "pnpm tailwindcss -i styles/main.css -o static/css/main.css -v --watch",
		"build": "pnpm tailwindcss -i styles/main.css -o static/css/main.css -v --minify"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.3.2",
		"concurrently": "^10.0.3",
		"cssnano": "^8.0.2",
		"tailwindcss": "4.3.2",
		"wrangler": "^4.99.0"
	}
}
